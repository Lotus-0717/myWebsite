---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  description?: string;
  descriptionZh?: string;
  image?: string;
  type?: 'website' | 'article';
  pubDate?: Date;
}

const {
  title,
  description = 'Personal website of Lotus Yeh — frontend engineer and product designer.',
  descriptionZh,
  image,
  type: typeProp,
  pubDate,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image ?? '/pic.png', Astro.site).toString();
const type = typeProp ?? 'website';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {descriptionZh && <meta name="description" lang="zh-Hant" content={descriptionZh} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- hreflang -->
    <link rel="alternate" hreflang="en" href={canonicalURL} />
    <link rel="alternate" hreflang="zh-Hant" href={`${canonicalURL}?lang=zh`} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:site_name" content="Lotus Yeh" />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="zh_TW" />
    {type === 'article' && pubDate && (
      <meta property="article:published_time" content={pubDate.toISOString()} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script is:inline>
      const saved = localStorage.getItem('theme');
      if (saved) document.documentElement.dataset.theme = saved;
      // Apply lang from URL param early so downstream JS can read it
      const _lp = new URLSearchParams(location.search).get('lang');
      if (_lp === 'zh') localStorage.setItem('lang', 'zh');
      else if (_lp === 'en' || _lp === '') localStorage.removeItem('lang');
    </script>
  </head>
  <body class="min-h-screen flex flex-col" style="background-color: var(--color-theme-dark); color: var(--color-theme-light); font-family: 'Ubuntu Mono', 'Noto Sans TC', monospace;">
    <!-- <ThemeToggle /> -->
    <Header />
    <main class="flex-1 max-w-5xl mx-auto w-full px-5 py-8">
      <slot />
    </main>
    <Footer />
    <script>
      import { initTranslator } from '../scripts/translator';
      document.addEventListener('DOMContentLoaded', initTranslator);
    </script>
  </body>
</html>
