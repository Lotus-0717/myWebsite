---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '葉書宏的個人網站' } = Astro.props;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline>
      const saved = localStorage.getItem('theme');
      if (saved) document.documentElement.dataset.theme = saved;
      // Apply lang from URL param early so downstream JS can read it
      const _lp = new URLSearchParams(location.search).get('lang');
      if (_lp === 'zh') localStorage.setItem('lang', 'zh');
      else if (_lp === 'en' || _lp === '') localStorage.removeItem('lang');
    </script>
  </head>
  <body class="min-h-screen flex flex-col" style="background-color: var(--color-theme-dark); color: var(--color-theme-light); font-family: 'Ubuntu Mono', 'Noto Sans TC', monospace;">
    <!-- <ThemeToggle /> -->
    <Header />
    <main class="flex-1 max-w-5xl mx-auto w-full px-5 py-8">
      <slot />
    </main>
    <Footer />
    <script>
      import { initTranslator } from '../scripts/translator';
      document.addEventListener('DOMContentLoaded', initTranslator);
    </script>
  </body>
</html>
