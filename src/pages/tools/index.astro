---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SecTit from '../../components/SecTit.astro';

const tools = [
  {
    title: 'Word Counter',
    description: 'Quickly count words and characters in any language',
    href: '/tools/word-counter',
  },
  {
    title: 'CSS Triangle Generator',
    description: 'Generate CSS-only triangles — pick direction, size, and color',
    href: '/tools/css-triangle',
  },
];
---

<BaseLayout title="Tools | Lotus Yeh" description="Some handy little tools">
  <SecTit text="Tools" />
  <p data-translate class="opacity-50 mb-8 mt-4">Some small tools born from vibe coding — feel free to use them.</p>

  <div class="grid gap-4 sm:grid-cols-2">
    {tools.map((tool) => (
      <a href={tool.href} class="block p-5 rounded-2xl transition-all hover:opacity-90" style="background-color: var(--color-theme-primary); color: var(--color-theme-light);">
        <h2 data-translate class="font-semibold mb-1">{tool.title}</h2>
        <p data-translate class="text-sm opacity-60">{tool.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>
