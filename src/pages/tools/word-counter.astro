---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionCard from '../../components/SectionCard.astro';
import SecTit from '../../components/SecTit.astro';
import WordCounter from '../../components/WordCounter.tsx';
---

<BaseLayout title="Word Counter | Lotus Yeh" description="Quickly count words and characters in any language">
  <a href="/tools" class="text-sm hover:underline mb-6 inline-block" style="color: var(--color-theme-secondary);">&larr; Back to Tools</a>
  <SecTit text="Word Counter" />
  <div class="mt-6">
    <SectionCard>
      <div class="w-full">
        <WordCounter client:load />
      </div>
    </SectionCard>
  </div>
</BaseLayout>
