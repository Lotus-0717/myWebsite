---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionCard from '../components/SectionCard.astro';
import SecTit from '../components/SecTit.astro';
import GlitchPhoto from '../components/GlitchPhoto.tsx';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const featuredProjects = (await getCollection('portfolio'))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const skills = [
  { category: '品牌與策略', items: ['品牌思維', '客戶溝通', '專案主導', '跨部門協作'] },
  { category: '產品與設計', items: ['UI/UX 審查', '視覺品質判斷', '響應式設計'] },
  { category: '前端開發', items: ['React', 'TypeScript', 'CSS/SCSS', 'Tailwind', 'Astro'] },
  { category: 'AI 協作', items: ['Prompt Engineering', 'Claude', 'Cursor', 'v0.dev'] },
  { category: '工具', items: ['Git', 'Figma', 'Vite'] },
];

const experiences = [
  {
    company: '禾意數位創意',
    companySub: 'Catch Design',
    start: 'Apr 2021',
    end: 'Dec 2023',
    items: [
      { title: '提供 UI/UX 設計建議', content: '主動提出改進方案，改善用戶界面和體驗，提高用戶滿意度和互動率。' },
      { title: '開發小遊戲活動網站', content: '負責從頭到尾的開發工作，不僅注重遊戲本身的互動性，也針對遊戲情境進行了體驗優化。' },
      { title: '打造品牌形象官網', content: '與設計師緊密合作，確保視覺風格的一致性，並與後端協作開發 API 接口。' },
      { title: '製作 Landing Page', content: '運用創意設計和技術實現，製作出符合客戶期望的 Landing Page。' },
      { title: '維護和優化 Vue.js 官網', content: '接手並改進既有的 Vue.js 專案，根據客戶需求進行定制化修改，提高了頁面性能和用戶體驗。' },
    ],
  },
  {
    company: '全職接案',
    companySub: 'Freelancer',
    start: 'Oct 2019',
    end: 'Apr 2021',
    items: [
      { title: '以品牌思維主導專案', content: '採用經營者視角主動參與決策，深化對商業策略和管理思維的理解，有效橋接技術實施與業務目標。' },
      { title: '客戶溝通與設計參與', content: '超越傳統工程師角色，主動參與前期設計和發想階段，確保技術實現與客戶需求高度一致。' },
      { title: '公益組織網站建置', content: '領導團隊完成公益組織網站全流程建置，包括設計、空間租用及開發，提升組織影響力。' },
      { title: '汽車品牌線上預購網站', content: '獨立負責切版與 API 串接，實現了流暢的用戶預購體驗，促進銷售增長。' },
      { title: '日用品品牌繪本遊戲網站', content: '運用 CSS3 實現繪本翻頁效果，並開發JS小遊戲（拖曳分類、走迷宮等），豐富用戶互動，提高用戶停留時間。' },
      { title: '銀行活動 Landing Page', content: '參與多個銀行活動 Landing Page 的製作，通過創意設計和技術實現，提高活動轉化率。' },
      { title: '數位行銷公司作品集網站開發', content: '運用 WordPress 實現具有直觀後台管理界面的網站，賦予客戶無需編程知識即可自主更新和編輯作品集的能力。' },
    ],
  },
  {
    company: '法樂數位創意',
    companySub: 'FLA Digital Creative',
    start: 'Mar 2017',
    end: 'Sep 2019',
    items: [
      { title: '跨部門協作', content: '積極與企劃和設計團隊溝通協調，確保設計與技術的一致性，提升專案效率與品質。' },
      { title: '後端協作與API整合', content: '與後端開發團隊緊密合作，實現 API 串接，確保數據的準確傳輸和動態功能。' },
      { title: '媒體追蹤與分析', content: '根據客戶需求埋設媒體追蹤碼，支持數據分析和用戶行為追蹤，助力精準營銷策略的制定。' },
      { title: '社群平台整合', content: '實現社群平台 API 串接，加強網站與社群媒體的互動連結，擴大品牌影響力和用戶參與度。' },
    ],
  },
  {
    company: '淡江大學 歷史系',
    companySub: 'Department of History, Tamkang University',
    start: 'Jul 2011',
    end: 'Mar 2016',
    items: [],
  },
];
---

<BaseLayout title="葉書宏 | Lotus Yeh" description="葉書宏的個人網站 — 前端工程師">
  <div class="flex flex-col gap-10">

    <!-- Profile -->
    <SectionCard>
      <GlitchPhoto client:load src="/pic.png" />
      <div class="text-center">
        <p class="text-4xl font-bold">葉書宏</p>
        <p class="text-2xl font-bold">Steven Yeh</p>
      </div>
      <div class="flex flex-col items-start gap-1">
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 512 512"><path d="M48 64C21.5 64 0 85.5 0 112c0 15.1 7.1 29.3 19.2 38.4L236.8 313.6c11.4 8.5 27 8.5 38.4 0L492.8 150.4c12.1-9.1 19.2-23.3 19.2-38.4c0-26.5-21.5-48-48-48H48zM0 176V384c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V176L294.4 339.2c-22.8 17.1-54 17.1-76.8 0L0 176z"/></svg>
          <p class="text-xl">lian82717pro@gmail.com</p>
        </div>
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 384 512"><path d="M215.7 499.2C267 435 384 279.4 384 192C384 86 298 0 192 0S0 86 0 192c0 87.4 117 243 168.3 307.2c12.3 15.3 35.1 15.3 47.4 0zM192 128a64 64 0 1 1 0 128 64 64 0 1 1 0-128z"/></svg>
          <p class="text-xl">台灣, 新北市</p>
        </div>
      </div>
    </SectionCard>

    <!-- Skills -->
    <div>
      <SecTit text="Skill" />
      <SectionCard>
        {skills.map((group) => (
          <div class="flex w-full flex-col items-start gap-2">
            <p class="inline-block px-2 py-1" style="background-color: var(--color-theme-secondary); color: var(--color-theme-dark);">
              {group.category}
            </p>
            <div class="flex flex-wrap gap-2">
              {group.items.map((item) => (
                <span class="border-2 px-2 py-1" style="border-color: var(--color-theme-secondary);">
                  {item}
                </span>
              ))}
            </div>
          </div>
        ))}
      </SectionCard>
    </div>

    <!-- Experience -->
    <div>
      <SecTit text="Experience" />
      <SectionCard>
        {experiences.map((exp, i) => (
          <div class="w-full">
            <div class="flex flex-col gap-5">
              <div>
                <p class="text-4xl font-bold">{exp.company}</p>
                <p class="text-2xl font-bold italic opacity-50">{exp.companySub}</p>
                <p class="text-right text-xl">{exp.start} - {exp.end}</p>
              </div>
              {exp.items.length > 0 && (
                <ul class="flex list-disc flex-col gap-2 pl-5">
                  {exp.items.map((item) => (
                    <li><strong>{item.title}</strong>: {item.content}</li>
                  ))}
                </ul>
              )}
            </div>
            {i < experiences.length - 1 && (
              <div class="mt-5 w-full border-b-2" style="border-color: var(--color-theme-secondary);"></div>
            )}
          </div>
        ))}
      </SectionCard>
    </div>

    <!-- Recent Posts -->
    <div>
      <SecTit text="Blog" />
      <div class="flex items-center justify-end mb-4">
        <a href="/blog" class="text-sm hover:underline" style="color: var(--color-theme-secondary);">查看全部 &rarr;</a>
      </div>
      <div class="space-y-4">
        {allPosts.map((post) => (
          <a href={`/blog/${post.id}`} class="block p-4 rounded-2xl transition-all hover:opacity-90" style="background-color: var(--color-theme-primary); color: var(--color-theme-light);">
            <h3 class="font-semibold text-lg mb-1">{post.data.title}</h3>
            <p class="text-sm opacity-60 mb-2">{post.data.description}</p>
            <div class="flex items-center gap-3 text-xs opacity-40">
              <time>{post.data.pubDate.toLocaleDateString('zh-Hant')}</time>
              <span class="px-2 py-0.5 rounded" style="background-color: var(--color-theme-secondary); color: var(--color-theme-dark);">{post.data.category}</span>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Featured Projects -->
    {featuredProjects.length > 0 && (
      <div>
        <SecTit text="Portfolio" />
        <div class="flex items-center justify-end mb-4">
          <a href="/portfolio" class="text-sm hover:underline" style="color: var(--color-theme-secondary);">查看全部 &rarr;</a>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {featuredProjects.map((project) => (
            <a href={`/portfolio/${project.id}`} class="block p-5 rounded-2xl transition-all hover:opacity-90" style="background-color: var(--color-theme-primary); color: var(--color-theme-light);">
              <h3 class="font-semibold text-lg mb-1">{project.data.title}</h3>
              <p class="text-sm opacity-60 mb-3">{project.data.description}</p>
              <div class="flex flex-wrap gap-1">
                {project.data.tech.map((t) => (
                  <span class="px-2 py-0.5 text-xs border rounded" style="border-color: var(--color-theme-secondary); color: var(--color-theme-secondary);">{t}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

  </div>
</BaseLayout>
