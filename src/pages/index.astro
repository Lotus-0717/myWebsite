---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionCard from '../components/SectionCard.astro';
import SecTit from '../components/SecTit.astro';
import GlitchPhoto from '../components/GlitchPhoto.tsx';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const featuredProjects = (await getCollection('portfolio'))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const skills = [
  { category: 'Brand & Strategy', items: ['Brand Thinking', 'Client Communication', 'Project Leadership', 'Cross-team Collaboration'] },
  { category: 'Product & Design', items: ['UI/UX Review', 'Visual Quality Judgment', 'Responsive Design'] },
  { category: 'Frontend', items: ['React', 'TypeScript', 'CSS/SCSS', 'Tailwind', 'Astro'] },
  { category: 'AI Collaboration', items: ['Prompt Engineering', 'Claude', 'Cursor', 'v0.dev'] },
  { category: 'Tools', items: ['Git', 'Figma', 'Vite'] },
];

const experiences = [
  {
    company: 'Catch Design',
    companySub: '禾意數位創意',
    start: 'Apr 2021',
    end: 'Dec 2023',
    items: [
      { title: 'UI/UX Design Consulting', content: 'Proactively proposed UI/UX improvements that enhanced user experience and increased engagement rates.' },
      { title: 'Interactive Game Microsites', content: 'Led end-to-end development of game-based campaign sites, focusing on interactivity and experience optimization.' },
      { title: 'Brand Corporate Websites', content: 'Collaborated closely with designers to maintain visual consistency and worked with backend teams on API integration.' },
      { title: 'Landing Page Development', content: 'Delivered creative and technically sound landing pages aligned with client expectations and campaign goals.' },
      { title: 'Vue.js Website Maintenance', content: 'Took ownership of existing Vue.js projects, implemented client-requested customizations, and improved performance and UX.' },
    ],
  },
  {
    company: 'Freelancer',
    companySub: '',
    start: 'Oct 2019',
    end: 'Apr 2021',
    items: [
      { title: 'Brand-driven Project Leadership', content: 'Adopted an owner mindset to actively participate in decisions, bridging technical execution with business objectives.' },
      { title: 'Client Communication & Design Involvement', content: 'Went beyond the engineering role to join early design and ideation phases, ensuring alignment between tech and client needs.' },
      { title: 'Non-profit Organization Website', content: 'Led a team through the full lifecycle of a non-profit website, including design, hosting, and development.' },
      { title: 'Automotive Pre-order Website', content: 'Independently handled frontend markup and API integration, delivering a smooth pre-order experience that drove sales.' },
      { title: 'Storybook Game Website', content: 'Used CSS3 to create page-turn animations and built JS mini-games (drag-and-drop sorting, maze, etc.) to boost engagement.' },
      { title: 'Bank Campaign Landing Pages', content: 'Contributed to multiple bank event landing pages, improving conversion rates through creative design and implementation.' },
      { title: 'Digital Agency Portfolio Site', content: 'Built a WordPress site with an intuitive CMS so clients could update their portfolio without any coding knowledge.' },
    ],
  },
  {
    company: 'FLA Digital Creative',
    companySub: '法樂數位創意',
    start: 'Mar 2017',
    end: 'Sep 2019',
    items: [
      { title: 'Cross-department Collaboration', content: 'Coordinated with planning and design teams to ensure design-tech consistency and improve project efficiency.' },
      { title: 'Backend Collaboration & API Integration', content: 'Worked closely with backend developers on API integration to ensure accurate data flow and dynamic functionality.' },
      { title: 'Media Tracking & Analytics', content: 'Implemented tracking tags per client requirements to support data analysis, user behavior tracking, and targeted marketing.' },
      { title: 'Social Platform Integration', content: 'Integrated social media APIs to strengthen the connection between websites and social channels, expanding brand reach.' },
    ],
  },
  {
    company: 'Tamkang University',
    companySub: 'Department of History',
    start: 'Jul 2011',
    end: 'Mar 2016',
    items: [],
  },
];
---

<BaseLayout title="Lotus Yeh" description="Lotus Yeh's personal website — Frontend Engineer">
  <div class="flex flex-col gap-10">

    <!-- Profile -->
    <SectionCard>
      <GlitchPhoto client:load src="/pic.png" />
      <div class="text-center">
        <p class="text-4xl font-bold">Lotus Yeh</p>
        <p class="text-2xl font-bold">葉書宏</p>
      </div>
      <div class="flex flex-col items-start gap-1">
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 512 512"><path d="M48 64C21.5 64 0 85.5 0 112c0 15.1 7.1 29.3 19.2 38.4L236.8 313.6c11.4 8.5 27 8.5 38.4 0L492.8 150.4c12.1-9.1 19.2-23.3 19.2-38.4c0-26.5-21.5-48-48-48H48zM0 176V384c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V176L294.4 339.2c-22.8 17.1-54 17.1-76.8 0L0 176z"/></svg>
          <p class="text-xl">lian82717pro@gmail.com</p>
        </div>
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 384 512"><path d="M215.7 499.2C267 435 384 279.4 384 192C384 86 298 0 192 0S0 86 0 192c0 87.4 117 243 168.3 307.2c12.3 15.3 35.1 15.3 47.4 0zM192 128a64 64 0 1 1 0 128 64 64 0 1 1 0-128z"/></svg>
          <p data-translate class="text-xl">New Taipei City, Taiwan</p>
        </div>
      </div>
    </SectionCard>

    <!-- Skills -->
    <div>
      <SecTit text="Skill" />
      <SectionCard>
        {skills.map((group) => (
          <div class="flex w-full flex-col items-start gap-2">
            <p data-translate class="inline-block px-2 py-1" style="background-color: var(--color-theme-secondary); color: var(--color-theme-dark);">
              {group.category}
            </p>
            <div class="flex flex-wrap gap-2">
              {group.items.map((item) => (
                <span data-translate class="border-2 px-2 py-1" style="border-color: var(--color-theme-secondary);">
                  {item}
                </span>
              ))}
            </div>
          </div>
        ))}
      </SectionCard>
    </div>

    <!-- Experience -->
    <div>
      <SecTit text="Experience" />
      <SectionCard>
        {experiences.map((exp, i) => (
          <div class="w-full">
            <div class="flex flex-col gap-5">
              <div>
                <p class="text-4xl font-bold">{exp.company}</p>
                <p class="text-2xl font-bold italic opacity-50">{exp.companySub}</p>
                <p class="text-right text-xl">{exp.start} - {exp.end}</p>
              </div>
              {exp.items.length > 0 && (
                <ul class="flex list-disc flex-col gap-2 pl-5">
                  {exp.items.map((item) => (
                    <li><strong data-translate>{item.title}</strong>: <span data-translate>{item.content}</span></li>
                  ))}
                </ul>
              )}
            </div>
            {i < experiences.length - 1 && (
              <div class="mt-5 w-full border-b-2" style="border-color: var(--color-theme-secondary);"></div>
            )}
          </div>
        ))}
      </SectionCard>
    </div>

    <!-- Recent Posts -->
    <div class="relative">
      <SecTit text="Blog" />
      <a href="/blog" class="absolute right-0 top-3 text-sm hover:underline z-10" style="color: var(--color-theme-secondary);"><span data-translate>View all</span> &rarr;</a>
      <div class="space-y-4">
        {allPosts.map((post) => (
          <a href={`/blog/${post.id}`} class="block p-4 md:p-8 rounded-2xl transition-all hover:opacity-90" style="background-color: var(--color-theme-primary); color: var(--color-theme-light);">
            <h3 data-translate class="font-semibold text-lg mb-1">{post.data.title}</h3>
            <p data-translate class="text-sm opacity-60 mb-2">{post.data.description}</p>
            <div class="flex items-center gap-3 text-xs opacity-40">
              <time>{post.data.pubDate.toLocaleDateString('en-US')}</time>
              <span class="px-2 py-0.5 rounded" style="background-color: var(--color-theme-secondary); color: var(--color-theme-dark);">{post.data.category}</span>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Featured Projects -->
    {featuredProjects.length > 0 && (
      <div class="relative">
        <SecTit text="Portfolio" />
        <a href="/portfolio" class="absolute right-0 top-3 text-sm hover:underline z-10" style="color: var(--color-theme-secondary);"><span data-translate>View all</span> &rarr;</a>
        <div class="grid gap-4 sm:grid-cols-2">
          {featuredProjects.map((project) => (
            <a href={`/portfolio/${project.id}`} class="block p-4 md:p-8 rounded-2xl transition-all hover:opacity-90" style="background-color: var(--color-theme-primary); color: var(--color-theme-light);">
              <h3 data-translate class="font-semibold text-lg mb-1">{project.data.title}</h3>
              <p data-translate class="text-sm opacity-60 mb-3">{project.data.description}</p>
              <div class="flex flex-wrap gap-1">
                {project.data.tech.map((t) => (
                  <span class="px-2 py-0.5 text-xs border rounded" style="border-color: var(--color-theme-secondary); color: var(--color-theme-secondary);">{t}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

  </div>
</BaseLayout>
