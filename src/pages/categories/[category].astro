---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SecTit from '../../components/SecTit.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const categories = [...new Set(posts.map((p) => p.data.category))];
  return categories.map((category) => ({
    params: { category },
    props: {
      category,
      posts: posts
        .filter((p) => p.data.category === category)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { category, posts } = Astro.props;
---

<BaseLayout title={`${category} | Lotus Yeh`} description={`All posts in category "${category}"`}>
  <a href="/blog" class="text-sm hover:underline mb-6 inline-block" style="color: var(--color-theme-secondary);">&larr; Back to Blog</a>
  <SecTit text={category} />
  <p class="opacity-50 mb-8 mt-4">{posts.length} post{posts.length !== 1 ? 's' : ''}</p>

  <div class="space-y-4">
    {posts.map((post) => (
      <a href={`/blog/${post.id}`} class="block p-5 rounded-2xl transition-all hover:opacity-90" style="background-color: var(--color-theme-primary); color: var(--color-theme-light);">
        <h2 class="font-semibold mb-1">{post.data.title}</h2>
        <p class="text-sm opacity-60 mb-2">{post.data.description}</p>
        <time class="text-xs opacity-40">{post.data.pubDate.toLocaleDateString('en-US')}</time>
      </a>
    ))}
  </div>
</BaseLayout>
