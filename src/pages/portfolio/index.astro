---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SecTit from '../../components/SecTit.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('portfolio'))
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);
---

<BaseLayout title="Portfolio | Lotus Yeh" description="My portfolio">
  <SecTit text="Portfolio" />

  <div class="grid gap-6 sm:grid-cols-2 mt-6">
    {projects.map((project) => (
      <a href={`/portfolio/${project.id}`} class="block p-5 rounded-2xl transition-all hover:opacity-90" style="background-color: var(--color-theme-primary); color: var(--color-theme-light);">
        <div class="flex items-start justify-between mb-2">
          <h2 class="text-lg font-semibold">{project.data.title}</h2>
          <span class="text-xs px-2 py-0.5 rounded" style={
            project.data.status === 'completed'
              ? 'background-color: var(--color-theme-secondary); color: var(--color-theme-dark);'
              : project.data.status === 'in-progress'
              ? 'border: 1px solid var(--color-theme-secondary); color: var(--color-theme-secondary);'
              : 'opacity: 0.5;'
          }>
            {project.data.status === 'completed' ? 'Completed' :
             project.data.status === 'in-progress' ? 'In Progress' : 'Archived'}
          </span>
        </div>
        <p class="text-sm opacity-60 mb-3">{project.data.description}</p>
        <div class="flex flex-wrap gap-1">
          {project.data.tech.map((t) => (
            <span class="px-2 py-0.5 text-xs border rounded" style="border-color: var(--color-theme-secondary); color: var(--color-theme-secondary);">{t}</span>
          ))}
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
