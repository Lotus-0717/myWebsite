---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SecTit from '../../components/SecTit.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('portfolio'))
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);
---

<BaseLayout title="Portfolio | Lotus Yeh" description="My portfolio">
  <SecTit text="Portfolio" />

  <div class="grid gap-6 sm:grid-cols-2 mt-6">
    {projects.map((project) => (
      <a href={`/portfolio/${project.id}`} class="flex gap-4 p-5 rounded-2xl transition-all hover:opacity-90" style="background-color: var(--color-theme-primary); color: var(--color-theme-light);">
        {project.data.cover ? (
          <div class="shrink-0 w-20 h-20 rounded-xl overflow-hidden">
            <img src={project.data.cover} alt={project.data.title} class="w-full h-full object-cover" />
          </div>
        ) : (
          <div class="shrink-0 w-20 h-20 rounded-xl flex items-center justify-center text-2xl" style="background-color: var(--color-theme-secondary); color: var(--color-theme-dark);">
            {project.data.title.charAt(0)}
          </div>
        )}
        <div class="flex flex-col min-w-0 flex-1">
          <div class="flex items-start justify-between mb-1 gap-2">
            <h2 data-translate class="text-lg font-semibold leading-tight">{project.data.title}</h2>
            <span data-translate class="text-xs px-2 py-0.5 rounded shrink-0" style={
              project.data.status === 'completed'
                ? 'background-color: var(--color-theme-secondary); color: var(--color-theme-dark);'
                : project.data.status === 'in-progress'
                ? 'border: 1px solid var(--color-theme-secondary); color: var(--color-theme-secondary);'
                : 'opacity: 0.5;'
            }>
              {project.data.status === 'completed' ? 'Completed' :
               project.data.status === 'in-progress' ? 'In Progress' : 'Archived'}
            </span>
          </div>
          <p data-translate class="text-sm opacity-60 mb-3 line-clamp-2">{project.data.description}</p>
          <div class="flex flex-wrap gap-1 mt-auto">
            {project.data.tech.map((t) => (
              <span class="px-2 py-0.5 text-xs border rounded" style="border-color: var(--color-theme-secondary); color: var(--color-theme-secondary);">{t}</span>
            ))}
          </div>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
