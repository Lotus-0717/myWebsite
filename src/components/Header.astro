---
const navItems = [
  { href: '/', label: '首頁' },
  { href: '/blog', label: '網誌' },
  { href: '/portfolio', label: '作品集' },
  { href: '/tools', label: '工具' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b" style="border-color: var(--color-theme-primary);">
  <nav class="max-w-5xl mx-auto px-5 py-4 flex items-center justify-between">
    <a href="/" class="text-xl font-bold transition-colors" style="color: var(--color-theme-secondary);">
      Lotus Yeh
    </a>
    <ul class="flex gap-6 text-sm">
      {navItems.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'transition-colors font-medium',
              currentPath === href || (href !== '/' && currentPath.startsWith(href))
                ? ''
                : 'opacity-60 hover:opacity-100',
            ]}
            style={
              currentPath === href || (href !== '/' && currentPath.startsWith(href))
                ? `color: var(--color-theme-secondary);`
                : `color: var(--color-theme-light);`
            }
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
